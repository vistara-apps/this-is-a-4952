# Domain Auctions Pro - Environment Configuration
# Copy this file to .env and fill in your actual API keys

# Alchemy API Configuration
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here
VITE_ALCHEMY_NETWORK=base-mainnet

# Reservoir API Configuration
VITE_RESERVOIR_API_KEY=your_reservoir_api_key_here

# OpenAI API Configuration
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Pinata IPFS Configuration
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_SECRET_KEY=your_pinata_secret_key_here

# Doma Oracles Configuration
VITE_DOMA_API_KEY=your_doma_api_key_here

# Privy Authentication Configuration
VITE_PRIVY_APP_ID=your_privy_app_id_here

# Turnkey Wallet Configuration
VITE_TURNKEY_API_KEY=your_turnkey_api_key_here

# Application Configuration
VITE_APP_NAME=Domain Auctions Pro
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# WebSocket Configuration
VITE_WS_ENDPOINT=wss://api.domainauctions.pro

# Base Chain Configuration
VITE_BASE_CHAIN_ID=8453
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_BASE_EXPLORER_URL=https://basescan.org

# Feature Flags
VITE_ENABLE_REAL_TIME=true
VITE_ENABLE_AI_INSIGHTS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=true

# Analytics Configuration
VITE_GOOGLE_ANALYTICS_ID=your_ga_id_here
VITE_MIXPANEL_TOKEN=your_mixpanel_token_here

# Error Tracking
VITE_SENTRY_DSN=your_sentry_dsn_here

# Development Configuration
VITE_DEBUG_MODE=true
VITE_MOCK_API=true
